# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Contraseñas: rondas bcrypt (10–14, por defecto 12)
# BCRYPT_SALT_ROUNDS=12

# Solo migración en entornos controlados: permite login si la BD tiene contraseña en texto plano
# y la re-hashea al primer login. En producción debe estar desactivado (omitir la variable).
# ALLOW_LEGACY_PLAINTEXT_LOGIN=true

# Solo desarrollo: incluir token de reset en la respuesta JSON de forgot-password (nunca en producción).
# PASSWORD_RESET_DEBUG_RESPONSE=true

# Server Configuration
PORT=3000

# Origen permitido para CORS (ej. http://localhost:5173). En desarrollo puedes usar *
# CORS_ORIGIN=http://localhost:5173

# Google Gemini API (Recomendado - Tier gratuito generoso)
# Obtén tu API key gratis en: https://makersuite.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face (Opcional - requiere plan pago)
HUGGING_FACE_API_KEY=your_hugging_face_token_here




SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER= EvaluacionTempranaUDEM@outlook.com
SMTP_PASS= ConcienciaAcademica4
SMTP_FROM="ConCiencia Académica EvaluacionTempranaUDEM@outlook.com"












