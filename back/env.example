# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Server Configuration
PORT=3000

# Google Gemini API (Recomendado - Tier gratuito generoso)
# Obtén tu API key gratis en: https://makersuite.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face (Opcional - requiere plan pago)
HUGGING_FACE_API_KEY=your_hugging_face_token_here

















