# =============================================================================
# ConCiencia Académica — raíz del monorepo (front + back)
# =============================================================================

# --- Dependencias ---
node_modules/
jspm_packages/
.pnp
.pnp.js

# --- Variables de entorno y secretos (nunca subir) ---
.env
.env.*
!.env.example
!**/env.example
*.pem
*.key

# --- Builds y compilados ---
dist/
build/
out/
.next/
.nuxt/
*.tsbuildinfo
.cache/
.parcel-cache/
.turbo/
.vercel/
.netlify/

# --- Backend (Node/TS) ---
back/dist/
back/coverage/

# --- Frontend (Vite/React) ---
front/dist/
front/build/
front/.vite/
*.local

# --- Tests y cobertura ---
coverage/
.nyc_output/
*.lcov

# --- Logs y temporales ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.tmp
*.temp
*.swp
*.swo
*~

# --- Sistema operativo ---
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# --- IDE / editores ---
.idea/
*.sublime-project
*.sublime-workspace
*.vsix
.ionide/

# VS Code: ignorar casi todo el folder; permitir utilidades compartidas
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# Historial local de extensiones
.history/

# --- Diseño / binarios pesados (ajusta si versionas assets) ---
*.psd
*.sketch
thumb/
# CSV de importación masiva en la raíz de back/ (datos locales; quita esta línea si quieres versionarlos)
/back/*.csv

# --- Backups ---
**/*.backup.*
**/*.back.*
*.bak

# --- Otros ---
*.orig
**/.eslintcache
